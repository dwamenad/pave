generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostVisibility {
  PUBLIC
  UNLISTED
}

enum PostStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum ModerationStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum ReportTargetType {
  POST
  COMMENT
}

enum ReportStatus {
  OPEN
  REVIEWED
  RESOLVED
}

enum ExportFormat {
  PDF
}

enum ExportStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id             String             @id @default(cuid())
  email          String?            @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  username       String?            @unique
  bio            String?
  preferences    Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  accounts       Account[]
  sessions       Session[]
  posts          Post[]
  comments       Comment[]
  postLikes      PostLike[]
  postSaves      PostSave[]
  reports        Report[]
  authoredTrips  Trip[]
  remixes        TripRemix[]        @relation("TripRemixByUser")
  exports        TripExport[]
  anonSessions   AnonymousSession[]
  followers      Follow[]           @relation("Followee")
  following      Follow[]           @relation("Follower")
  blockedUsers   Block[]            @relation("Blocker")
  blockedByUsers Block[]            @relation("Blocked")
  events         Event[]
  notifications  Notification[]
  feedImpressions FeedImpression[]
  feedActions    FeedAction[]
  shareAttributions ShareAttribution[] @relation("ShareInviter")
  mobileSessions MobileSession[]
  mobileRefreshTokens MobileRefreshToken[]
  devices       Device[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MobileSession {
  id                  String   @id @default(cuid())
  userId              String
  deviceId            String?
  accessTokenJti      String   @unique
  refreshTokenVersion Int      @default(1)
  createdAt           DateTime @default(now())
  expiresAt           DateTime
  revokedAt           DateTime?
  lastSeenAt          DateTime @default(now())

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  device        Device?              @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  refreshTokens MobileRefreshToken[]

  @@index([userId, createdAt])
  @@index([deviceId, createdAt])
  @@index([expiresAt])
}

model MobileRefreshToken {
  id            String   @id @default(cuid())
  sessionId     String
  userId        String
  tokenHash     String   @unique
  expiresAt     DateTime
  revokedAt     DateTime?
  rotatedFromId String?
  createdAt     DateTime @default(now())

  session     MobileSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  rotatedFrom MobileRefreshToken?  @relation("MobileRefreshRotation", fields: [rotatedFromId], references: [id], onDelete: SetNull)
  rotatedInto MobileRefreshToken[] @relation("MobileRefreshRotation")

  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Device {
  id             String   @id @default(cuid())
  userId         String
  installationId String
  platform       String
  appVersion     String?
  deviceName     String?
  pushToken      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastSeenAt     DateTime @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions MobileSession[]

  @@unique([userId, installationId])
  @@index([userId, updatedAt])
  @@index([pushToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AnonymousSession {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  events Event[]

  @@index([token])
}

model Trip {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  centerLat   Float
  centerLng   Float
  placeId     String?
  authorId    String?
  isPublic    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  author      User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  days        TripDay[]
  invites     GroupInvite[]
  votes       Vote[]
  posts       Post[]
  exports     TripExport[]
  remixedFrom TripRemix[]   @relation("SourceTrip")
  remixedInto TripRemix[]   @relation("RemixedTrip")
  shares      ShareAttribution[]

  @@index([slug])
  @@index([authorId])
}

model TripDay {
  id       String     @id @default(cuid())
  tripId   String
  dayIndex Int

  trip  Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items TripItem[]

  @@unique([tripId, dayIndex])
  @@index([tripId])
}

model TripItem {
  id         String   @id @default(cuid())
  tripDayId  String
  placeId    String
  name       String
  lat        Float
  lng        Float
  category   String
  orderIndex Int
  notes      String?

  tripDay TripDay @relation(fields: [tripDayId], references: [id], onDelete: Cascade)

  @@index([tripDayId])
  @@index([placeId])
}

model GroupInvite {
  id        String   @id @default(cuid())
  tripId    String
  token     String   @unique
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([token])
}

model Vote {
  id            String   @id @default(cuid())
  tripId        String
  tokenOrUserId String
  placeId       String
  voteValue     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, tokenOrUserId, placeId])
  @@index([tripId, placeId])
}

model PlaceCache {
  placeId   String   @id
  json      Json
  fetchedAt DateTime @default(now())

  @@index([fetchedAt])
}

model NearbyCache {
  cacheKey  String   @id
  json      Json
  fetchedAt DateTime @default(now())

  @@index([fetchedAt])
}

model Post {
  id               String         @id @default(cuid())
  authorId         String
  tripId           String
  caption          String
  mediaUrl         String?
  visibility       PostVisibility @default(PUBLIC)
  destinationLabel String?
  status           PostStatus     @default(ACTIVE)
  tags             String[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  author      User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  trip        Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  sourceLinks PostSourceLink[]
  likes       PostLike[]
  saves       PostSave[]
  comments    Comment[]
  reports     Report[]
  impressions FeedImpression[]
  actions     FeedAction[]
  shares      ShareAttribution[]

  @@index([authorId, createdAt])
  @@index([status, visibility, createdAt])
}

model PostSourceLink {
  id           String   @id @default(cuid())
  postId       String?
  url          String
  domain       String
  title        String?
  description  String?
  thumbnailUrl String?
  parsedHints  String[]
  fetchedAt    DateTime @default(now())

  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([domain])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
}

model PostSave {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
}

model Comment {
  id        String           @id @default(cuid())
  postId    String
  authorId  String
  body      String
  status    ModerationStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  post    Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reports Report[]

  @@index([postId, createdAt])
  @@index([authorId])
}

model Report {
  id         String           @id @default(cuid())
  targetType ReportTargetType
  targetId   String
  reporterId String
  reason     String
  status     ReportStatus     @default(OPEN)
  postId     String?
  commentId  String?
  createdAt  DateTime         @default(now())

  reporter User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  post     Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment  Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([status, createdAt])
  @@index([reporterId])
}

model TripRemix {
  id           String   @id @default(cuid())
  sourceTripId String
  remixedTripId String
  remixedById  String
  createdAt    DateTime @default(now())

  sourceTrip  Trip @relation("SourceTrip", fields: [sourceTripId], references: [id], onDelete: Cascade)
  remixedTrip Trip @relation("RemixedTrip", fields: [remixedTripId], references: [id], onDelete: Cascade)
  remixedBy   User @relation("TripRemixByUser", fields: [remixedById], references: [id], onDelete: Cascade)

  @@unique([sourceTripId, remixedTripId])
  @@index([remixedById])
  @@index([createdAt])
}

model TripExport {
  id            String       @id @default(cuid())
  tripId         String
  requestedById  String?
  format         ExportFormat
  status         ExportStatus @default(PENDING)
  filePathOrUrl  String?
  error          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  trip        Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  requestedBy User? @relation(fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([tripId, createdAt])
  @@index([requestedById])
}

model Follow {
  id         String   @id @default(cuid())
  followerId String
  followeeId String
  createdAt  DateTime @default(now())

  follower User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee User @relation("Followee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@unique([followerId, followeeId])
  @@index([followerId, createdAt])
  @@index([followeeId, createdAt])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId, createdAt])
  @@index([blockedId, createdAt])
}

model Event {
  id            String   @id @default(cuid())
  userId        String?
  anonSessionId String?
  name          String
  props         Json?
  sessionId     String?
  createdAt     DateTime @default(now())

  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  anonSession AnonymousSession? @relation(fields: [anonSessionId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@index([userId, createdAt])
  @@index([anonSessionId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  entityId  String?
  payload   Json?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model FeedImpression {
  id        String   @id @default(cuid())
  userId    String?
  postId    String
  sessionId String
  source    String
  position  Int
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  post Post  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
}

model FeedAction {
  id         String   @id @default(cuid())
  userId     String?
  postId     String
  actionType String
  source     String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  post Post  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, actionType, createdAt])
  @@index([userId, createdAt])
}

model ShareAttribution {
  id          String    @id @default(cuid())
  tripId      String?
  postId      String?
  inviterId   String?
  channel     String
  token       String    @unique
  destination String?
  openedAt    DateTime?
  createdAt   DateTime  @default(now())

  trip    Trip?  @relation(fields: [tripId], references: [id], onDelete: SetNull)
  post    Post?  @relation(fields: [postId], references: [id], onDelete: SetNull)
  inviter User?  @relation("ShareInviter", fields: [inviterId], references: [id], onDelete: SetNull)

  @@index([inviterId, createdAt])
  @@index([tripId, createdAt])
  @@index([postId, createdAt])
  @@index([channel, createdAt])
}
